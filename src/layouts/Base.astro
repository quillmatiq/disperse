---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Disperse" } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <slot name="head" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
</head>
<body>
  <slot />
</body>
</html>
